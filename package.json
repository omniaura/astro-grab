{
  "name": "astro-grab",
  "version": "0.1.0",
  "description": "Hold a key, hover, click — grab any element's source context for AI agents. Astro devtool.",
  "type": "module",
  "main": "./dist/integration.js",
  "types": "./dist/integration.d.ts",
  "exports": {
    ".": {
      "types": "./dist/integration.d.ts",
      "import": "./dist/integration.js"
    },
    "./client": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "astro",
    "astro-integration",
    "devtools",
    "developer-tools",
    "ai",
    "cursor",
    "claude",
    "grab",
    "source-location",
    "inspector"
  ],
  "author": "OmniAura",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/omniaura/astro-grab.git"
  },
  "homepage": "https://github.com/omniaura/astro-grab",
  "bugs": {
    "url": "https://github.com/omniaura/astro-grab/issues"
  },
  "peerDependencies": {
    "astro": ">=4.0.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "astro": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^17.4.7",
    "@types/node": "^25.6.0",
    "astro": "^5.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0"
  }
}
